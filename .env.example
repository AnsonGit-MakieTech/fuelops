SECRET_KEY=replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=
POSTGRES_DB=fuelops
POSTGRES_USER=fuelops
POSTGRES_PASSWORD=replace-with-a-url-safe-password
WEB_PORT=8000
GUNICORN_CMD_ARGS=--workers=3 --threads=2 --timeout=60 --access-logfile=- --error-logfile=- --no-control-socket
RUN_MIGRATIONS=True
COLLECT_STATIC=True
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
TRUST_PROXY_SSL_HEADER=False
REGISTRATION_ENABLED=True
EMAIL_VERIFICATION_REQUIRED=False
DEFAULT_FROM_EMAIL=FuelOps <noreply@example.com>
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
